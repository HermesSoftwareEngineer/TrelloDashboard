{
  "buildCommand": "cd trellodashboard && npm install && npm run build",
  "outputDirectory": "trellodashboard/dist",
  "installCommand": "cd trellodashboard && npm install",
  "rewrites": [
    {
      "source": "/api/trello/(.*)",
      "destination": "https://api.trello.com/1/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
